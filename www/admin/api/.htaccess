# /admin/api/.htaccess
Order Deny,Allow
Deny from all

# Разрешить доступ только из админки
SetEnvIfNoCase Referer "^https?://[^/]+/admin/" internal
Allow from env=internal

# Запрет всего остального
<FilesMatch "\.php$">
    Order Deny,Allow
    Deny from all
    Allow from env=internal
</FilesMatch>